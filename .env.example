# All four services now use this app's own shared credentials (one Spotify/YouTube/Deezer
# app that every visitor logs into) instead of asking each visitor to register their own —
# see README.md for why, and the platform-imposed user-cap tradeoff that comes with it.

# Spotify Developer API credentials (developer.spotify.com/dashboard)
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Redirect URI must match what you configured in Spotify Developer Dashboard
# e.g., http://localhost:5173/ for local development
VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173/

# YouTube Data API v3 credentials (console.cloud.google.com)
VITE_YOUTUBE_CLIENT_ID=your_youtube_client_id_here

# Redirect URI must match what you configured in the Google Cloud Console
VITE_YOUTUBE_REDIRECT_URI=http://localhost:5173/

# Deezer App ID (developers.deezer.com/myapps) — not secret, sent in the browser redirect
# URL either way, so it's a client-side var like the two above.
VITE_DEEZER_APP_ID=your_deezer_app_id_here

# Yandex Music and Deezer's secret both stay server-side only (never in this file, never
# VITE_-prefixed) — set these directly in your Vercel project's environment variables,
# used only by the api/ proxy functions:
#   YANDEX_CLIENT_ID
#   YANDEX_CLIENT_SECRET
#   DEEZER_APP_ID       (same value as VITE_DEEZER_APP_ID above)
#   DEEZER_APP_SECRET
