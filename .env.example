# Spotify Developer API credentials (developer.spotify.com/dashboard)
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Redirect URI must match what you configured in Spotify Developer Dashboard
# e.g., http://localhost:5173/ for local development
VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173/

# YouTube Data API v3 credentials (console.cloud.google.com)
VITE_YOUTUBE_CLIENT_ID=your_youtube_client_id_here

# Redirect URI must match what you configured in the Google Cloud Console
VITE_YOUTUBE_REDIRECT_URI=http://localhost:5173/

# Yandex Music and Deezer are not configured here:
# - Yandex Music uses a shared OAuth app; only the Vercel proxy functions in
#   api/ need YANDEX_CLIENT_ID / YANDEX_CLIENT_SECRET as server-side env vars
#   (set those in your Vercel project settings, not this file).
# - Deezer credentials (App ID + Secret Key) are entered directly in the app's
#   login screen, not via env vars.
